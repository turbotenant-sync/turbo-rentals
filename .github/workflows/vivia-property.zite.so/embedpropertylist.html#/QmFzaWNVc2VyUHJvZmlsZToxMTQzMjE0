<div class="toast" id="toast"></div>

<script>
const TITLES = {
  dashboard:'Dashboard',properties:'Properties',listings:'Listings',
  applications:'Applications',screening:'Screening',leases:'Leases',
  rent:'Rent Collection',accounting:'Accounting',maintenance:'Maintenance',
  messages:'Messages',payments:'Stripe & Policies',email:'Email / SendGrid',setup:'Setup & Config'
};

function nav(id, btn) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (btn) {
    btn.classList.add('active');
  } else {
    document.querySelectorAll('.nav-item').forEach(n => {
      if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + id + "'")) n.classList.add('active');
    });
  }
  document.getElementById('topbarTitle').textContent = TITLES[id] || id;
  window.scrollTo(0, 0);
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });
});

let toastTimer;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '✓ ' + msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}

function sendEmail() {
  const to = document.getElementById('sgTo').value;
  const subject = document.getElementById('sgSubject').value;
  const body = document.getElementById('sgBody').value;
  if (!to || !subject) { document.getElementById('sgStatus').innerHTML = '<div class="sg-status warn">⚠ Please enter a recipient email and subject.</div>'; return; }
  document.getElementById('sgStatus').innerHTML = '<div class="sg-status ok">✓ Email queued via SendGrid API · From: lease@viviaproperty.com → ' + to + '</div>';
  toast('Email sent via SendGrid to ' + to);
}

function clearEmail() {
  ['sgTo','sgSubject','sgBody'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('sgStatus').innerHTML = '';
}
</script>
