<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>VIVIA — Owner Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --navy:#0D2B4E;--navy-mid:#13366A;--navy-light:#1a4a8a;
  --gold:#C8A96E;--gold-light:#E8D5A8;--gold-dim:rgba(200,169,110,.18);--gold-bg:rgba(200,169,110,.08);
  --cream:#F7F3EC;--cream-dark:#EDE8DF;--border:#DDD5C4;
  --slate:#4A6580;--slate-lt:#6A8099;--white:#fff;
  --green:#1a7a4a;--green-bg:rgba(26,122,74,.1);
  --red:#c0392b;--red-bg:rgba(192,57,43,.08);
  --amber:#b8860b;--amber-bg:rgba(184,134,11,.1);
  --sidebar-w:224px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter',sans-serif;background:var(--cream);color:var(--navy);display:flex;min-height:100vh;font-size:13px;}

/* ── SIDEBAR ── */
.sidebar{width:var(--sidebar-w);min-width:var(--sidebar-w);background:var(--navy);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto;}
.sb-logo{padding:20px 18px 16px;border-bottom:1px solid rgba(200,169,110,.2);}
.logo-mark{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:var(--gold);letter-spacing:.14em;}
.logo-mark span{color:rgba(255,255,255,.5);font-weight:400;font-size:18px;}
.logo-sub{font-size:9px;color:rgba(200,169,110,.45);letter-spacing:.2em;text-transform:uppercase;margin-top:2px;}
.sb-section{padding:14px 14px 4px;font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(200,169,110,.38);}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 14px;font-size:12px;font-weight:500;color:rgba(255,255,255,.52);cursor:pointer;border-radius:6px;margin:1px 8px;transition:all .13s;border:none;background:none;width:calc(100% - 16px);text-align:left;}
.nav-item:hover{background:rgba(200,169,110,.1);color:rgba(255,255,255,.82);}
.nav-item.active{background:var(--gold-dim);color:var(--gold);}
.nav-icon{font-size:14px;width:18px;text-align:center;flex-shrink:0;}
.nav-badge{margin-left:auto;background:var(--gold);color:var(--navy);font-size:9px;font-weight:800;padding:1px 6px;border-radius:9px;}
.sb-footer{margin-top:auto;padding:14px;border-top:1px solid rgba(200,169,110,.15);}
.owner-chip{display:flex;align-items:center;gap:9px;}
.owner-av{width:30px;height:30px;border-radius:50%;background:var(--gold-dim);border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--gold);}
.owner-name{font-size:11px;font-weight:600;color:rgba(255,255,255,.78);}
.owner-role{font-size:10px;color:rgba(200,169,110,.55);}

/* ── MAIN ── */
.main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;}
.topbar{background:var(--white);border-bottom:1px solid var(--border);padding:12px 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--navy);}
.topbar-actions{display:flex;gap:9px;align-items:center;}
.topbar-btn{background:var(--navy);color:var(--gold);border:none;padding:7px 16px;border-radius:6px;font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:.04em;transition:opacity .18s;}
.topbar-btn:hover{opacity:.85;}
.topbar-btn.ghost{background:transparent;color:var(--slate);border:1px solid var(--border);font-family:'Inter',sans-serif;font-size:11px;font-weight:600;}
.live-dot{width:7px;height:7px;border-radius:50%;background:#1a7a4a;display:inline-block;margin-right:4px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.35;}}
.page-body{padding:22px 26px;flex:1;}

/* ── VIEWS ── */
.view{display:none;}
.view.active{display:block;}

/* ── STAT CARDS ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.stat-card{background:var(--white);border-radius:9px;padding:16px 18px;border:1px solid var(--border);position:relative;overflow:hidden;}
.stat-card::after{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--gold);}
.stat-label{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--slate-lt);margin-bottom:5px;}
.stat-value{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--navy);line-height:1;}
.stat-meta{font-size:10px;color:var(--slate-lt);margin-top:4px;}
.stat-up{color:var(--green);}
.stat-down{color:var(--red);}
.stat-amber{color:var(--amber);}

/* ── SECTION HEADER ── */
.section-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.section-title{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:700;color:var(--navy);}
.section-link{font-size:11px;color:var(--gold);font-weight:600;cursor:pointer;text-decoration:none;border:none;background:none;}

/* ── TABLE ── */
.data-table{width:100%;border-collapse:collapse;background:var(--white);border-radius:9px;overflow:hidden;border:1px solid var(--border);}
.data-table th{padding:10px 14px;font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--slate-lt);background:var(--cream);border-bottom:1px solid var(--border);text-align:left;}
.data-table td{padding:11px 14px;font-size:12px;color:var(--navy);border-bottom:1px solid var(--cream-dark);}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:rgba(247,243,236,.5);}
.mono{font-family:'Courier New',monospace;font-size:10px;color:var(--slate);}

/* ── BADGE ── */
.badge{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;}
.badge-green{background:var(--green-bg);color:var(--green);}
.badge-gold{background:var(--gold-dim);color:#8B6914;}
.badge-red{background:var(--red-bg);color:var(--red);}
.badge-amber{background:var(--amber-bg);color:var(--amber);}
.badge-navy{background:rgba(13,43,78,.1);color:var(--navy);}
.badge-blue{background:rgba(24,95,165,.1);color:#185fa5;}

/* ── BUTTONS ── */
.btn-sm{padding:6px 12px;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer;border:none;transition:all .13s;letter-spacing:.03em;}
.btn-sm-primary{background:var(--navy);color:var(--gold);}
.btn-sm-ghost{background:transparent;color:var(--slate);border:1px solid var(--border);}
.btn-sm:hover{opacity:.83;}

/* ── WORKFLOW ── */
.wf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:22px;}
.wf-card{background:var(--white);border-radius:9px;border:1px solid var(--border);padding:18px;cursor:pointer;transition:all .18s;position:relative;}
.wf-card:hover{border-color:var(--gold);box-shadow:0 3px 14px rgba(200,169,110,.14);}
.wf-card.done{border-left:3px solid var(--green);}
.wf-card.active-wf{border-left:3px solid var(--gold);}
.wf-card.pending{border-left:3px solid var(--slate-lt);}
.wf-num{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--gold-light);margin-bottom:4px;}
.wf-title{font-weight:700;font-size:12px;color:var(--navy);margin-bottom:3px;}
.wf-desc{font-size:10px;color:var(--slate-lt);line-height:1.5;}
.wf-arrow{position:absolute;top:50%;right:-8px;transform:translateY(-50%);background:var(--gold);color:var(--navy);width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;z-index:2;}

/* ── PROP CARDS ── */
.props-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.prop-card{background:var(--white);border-radius:9px;border:1px solid var(--border);overflow:hidden;transition:box-shadow .18s;}
.prop-card:hover{box-shadow:0 4px 18px rgba(13,43,78,.08);}
.prop-img{height:100px;background:linear-gradient(135deg,var(--navy),var(--navy-mid));display:flex;align-items:center;justify-content:center;font-size:32px;position:relative;}
.prop-tag{position:absolute;top:8px;right:8px;}
.prop-body{padding:14px;}
.prop-address{font-weight:700;font-size:13px;color:var(--navy);}
.prop-city{font-size:11px;color:var(--slate-lt);}
.prop-stats{display:flex;gap:12px;margin-top:9px;padding-top:9px;border-top:1px solid var(--cream-dark);}
.prop-stat{font-size:10px;color:var(--slate-lt);}
.prop-stat strong{display:block;font-size:13px;font-weight:700;color:var(--navy);}
.prop-actions{display:flex;gap:7px;margin-top:10px;}
.prop-id{font-family:monospace;font-size:10px;color:var(--slate-lt);}

/* ── APP ROWS ── */
.app-row{display:flex;align-items:center;gap:12px;padding:13px 16px;background:var(--white);border-radius:8px;border:1px solid var(--border);margin-bottom:9px;transition:box-shadow .13s;}
.app-row:hover{box-shadow:0 2px 10px rgba(13,43,78,.07);}
.app-avatar{width:36px;height:36px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;color:var(--gold);flex-shrink:0;}
.app-info{flex:1;}
.app-name{font-weight:700;font-size:13px;color:var(--navy);}
.app-detail{font-size:10px;color:var(--slate-lt);}
.app-score{text-align:center;min-width:52px;}
.score-num{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;}
.score-lbl{font-size:9px;color:var(--slate-lt);letter-spacing:.07em;text-transform:uppercase;}
.app-acts{display:flex;gap:6px;flex-shrink:0;}

/* ── SCREENING ── */
.screen-card{background:var(--white);border-radius:9px;border:1px solid var(--border);padding:18px;margin-bottom:12px;}
.screen-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.score-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;}
.score-box{background:var(--cream);border-radius:7px;padding:11px;text-align:center;}
.score-val{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;}
.score-tag{font-size:9px;color:var(--slate-lt);text-transform:uppercase;letter-spacing:.07em;margin-top:2px;}

/* ── LEASE ── */
.lease-row{display:flex;align-items:center;gap:12px;padding:13px 16px;background:var(--white);border-radius:8px;border:1px solid var(--border);margin-bottom:9px;}
.lease-icon{font-size:20px;flex-shrink:0;}
.lease-info{flex:1;}
.lease-name{font-weight:700;font-size:13px;color:var(--navy);}
.lease-dates{font-size:10px;color:var(--slate-lt);}
.lease-bar{height:3px;background:var(--cream-dark);border-radius:2px;margin-top:6px;overflow:hidden;}
.lease-fill{height:100%;background:var(--gold);border-radius:2px;}

/* ── RENT ── */
.rent-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px;}
.rent-card{background:var(--white);border-radius:9px;padding:16px;border:1px solid var(--border);text-align:center;}
.rent-amount{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;}
.rent-label{font-size:10px;color:var(--slate-lt);margin-top:3px;text-transform:uppercase;letter-spacing:.07em;}
.pm-grid{display:flex;flex-wrap:wrap;gap:7px;margin-top:14px;}

/* ── ACCOUNTING ── */
.acct-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:18px;}
.acct-card{background:var(--white);border-radius:9px;padding:16px;border:1px solid var(--border);}
.acct-title{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--slate-lt);margin-bottom:10px;}
.acct-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--cream-dark);font-size:12px;}
.acct-row:last-child{border-bottom:none;font-weight:700;font-size:13px;}
.acct-in{color:var(--green);}
.acct-ex{color:var(--red);}

/* ── MAINTENANCE ── */
.maint-item{display:flex;gap:12px;align-items:flex-start;padding:13px 16px;background:var(--white);border-radius:8px;border:1px solid var(--border);margin-bottom:9px;}
.maint-icon-box{width:38px;height:38px;border-radius:7px;background:var(--cream);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.maint-body{flex:1;}
.maint-title{font-weight:600;font-size:13px;color:var(--navy);}
.maint-meta{font-size:10px;color:var(--slate-lt);margin-top:2px;}
.maint-right{text-align:right;flex-shrink:0;}

/* ── MESSAGES ── */
.msg-list{background:var(--white);border-radius:9px;border:1px solid var(--border);overflow:hidden;}
.msg-item{display:flex;gap:11px;padding:13px 16px;border-bottom:1px solid var(--cream-dark);cursor:pointer;transition:background .13s;}
.msg-item:hover{background:var(--cream);}
.msg-item:last-child{border-bottom:none;}
.msg-item.unread{background:rgba(200,169,110,.04);}
.msg-av{width:34px;height:34px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;}
.msg-body{flex:1;min-width:0;}
.msg-name{font-weight:700;font-size:13px;color:var(--navy);display:flex;justify-content:space-between;}
.msg-preview{font-size:11px;color:var(--slate-lt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px;}
.msg-time{font-size:10px;color:var(--slate-lt);}
.unread-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);margin-top:7px;flex-shrink:0;}

/* ── SETUP ── */
.setup-item{display:flex;align-items:center;gap:12px;padding:13px 16px;background:var(--white);border-radius:8px;border:1px solid var(--border);margin-bottom:8px;}
.setup-check{width:21px;height:21px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
.check-done{background:var(--green-bg);color:var(--green);border:1.5px solid var(--green);}
.check-todo{background:var(--cream);color:var(--slate-lt);border:1.5px dashed var(--border);}
.setup-label{font-size:13px;font-weight:600;color:var(--navy);flex:1;}
.setup-sub{font-size:10px;color:var(--slate-lt);}

/* ── STRIPE SECTION ── */
.stripe-panel{background:var(--white);border-radius:9px;border:1px solid var(--border);padding:20px;margin-bottom:18px;}
.stripe-section-title{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--slate-lt);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--cream-dark);}
.stripe-row{display:flex;align-items:flex-start;gap:14px;padding:10px 0;border-bottom:1px solid var(--cream-dark);}
.stripe-row:last-child{border-bottom:none;}
.stripe-label{font-size:12px;font-weight:600;color:var(--navy);min-width:220px;flex-shrink:0;}
.stripe-value{font-size:12px;color:var(--slate);flex:1;}
.stripe-value a{color:var(--navy-light);text-decoration:none;}
.stripe-value a:hover{text-decoration:underline;}
.stripe-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;}
.stripe-note{font-size:10px;color:var(--slate-lt);margin-top:3px;}
.policy-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}

/* ── SENDGRID ── */
.sg-panel{background:var(--white);border-radius:9px;border:1px solid var(--border);overflow:hidden;margin-bottom:18px;}
.sg-header{background:var(--navy);color:var(--gold);padding:12px 18px;display:flex;align-items:center;justify-content:space-between;}
.sg-header-title{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;}
.sg-body{padding:18px;}
.sg-row{display:flex;gap:10px;margin-bottom:11px;}
.sg-group{flex:1;}
.sg-group label{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--slate);display:block;margin-bottom:4px;}
.sg-group input,.sg-group select,.sg-group textarea{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-family:'Inter',sans-serif;font-size:12px;color:var(--navy);background:var(--white);}
.sg-group input:focus,.sg-group select:focus{outline:none;border-color:var(--gold);}
.sg-status{display:flex;align-items:center;gap:7px;padding:10px 14px;border-radius:7px;font-size:12px;margin-top:4px;}
.sg-status.ok{background:var(--green-bg);color:var(--green);}
.sg-status.warn{background:var(--amber-bg);color:var(--amber);}

/* ── TT EMBED ── */
.tt-embed-wrap{background:var(--white);border-radius:9px;border:1px solid var(--border);overflow:hidden;margin-bottom:18px;}
.tt-embed-hd{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.tt-embed-hd-title{font-weight:700;font-size:13px;color:var(--navy);}
iframe.tt-embed{width:100%;height:1240px;border:none;display:block;}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(13,43,78,.5);z-index:200;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--white);border-radius:11px;width:520px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 18px 55px rgba(0,0,0,.22);}
.modal-header{padding:20px 22px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;color:var(--navy);}
.modal-close{background:none;border:none;font-size:19px;cursor:pointer;color:var(--slate-lt);}
.modal-body{padding:20px 22px;}
.fm-row{display:flex;gap:10px;margin-bottom:12px;}
.fm-group{flex:1;display:flex;flex-direction:column;}
.fm-group label{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--slate);margin-bottom:4px;}
.fm-group input,.fm-group select,.fm-group textarea{padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-family:'Inter',sans-serif;font-size:12px;color:var(--navy);background:var(--white);}
.fm-group input:focus,.fm-group select:focus{outline:none;border-color:var(--gold);}
.fm-actions{display:flex;gap:9px;margin-top:6px;}
.btn-primary{background:linear-gradient(135deg,var(--navy),var(--navy-mid));color:var(--gold);border:none;padding:10px 26px;border-radius:6px;font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .18s;}
.btn-primary:hover{opacity:.88;}
.btn-cancel{background:transparent;color:var(--slate);border:1px solid var(--border);padding:9px 18px;border-radius:6px;font-size:12px;cursor:pointer;}

/* ── TOAST ── */
.toast{position:fixed;bottom:22px;right:22px;background:var(--navy);color:var(--gold);padding:11px 18px;border-radius:7px;font-size:12px;font-weight:600;z-index:400;transform:translateY(70px);opacity:0;transition:all .28s;border:1px solid var(--gold-dim);max-width:320px;}
.toast.show{transform:translateY(0);opacity:1;}

/* ── NOTICE BOX ── */
.notice{border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:12px;}
.notice-gold{background:var(--gold-bg);border:1px solid rgba(200,169,110,.3);color:var(--navy);}
.notice-green{background:var(--green-bg);border:1px solid rgba(26,122,74,.2);color:var(--green);}
.notice-amber{background:var(--amber-bg);border:1px solid rgba(184,134,11,.2);color:var(--amber);}

/* ── TRACKING ID BADGE ── */
.trk{font-family:'Courier New',monospace;font-size:10px;background:rgba(13,43,78,.07);color:var(--slate);padding:2px 6px;border-radius:4px;display:inline-block;}

/* ── QUICK LINKS ── */
.qlinks{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;}

/* ── PROGRESS BAR ── */
.prog-wrap{margin-top:5px;}
.prog-track{height:4px;background:var(--cream-dark);border-radius:2px;overflow:hidden;}
.prog-fill{height:100%;border-radius:2px;background:var(--gold);}

@media(max-width:900px){
  .sidebar{width:56px;min-width:56px;}
  .sidebar .logo-mark span,.logo-sub,.nav-item>span:not(.nav-icon),.sb-section,.owner-name,.owner-role,.nav-badge{display:none;}
  .nav-item{justify-content:center;padding:11px;}
  .main{margin-left:56px;}
  .stats-grid,.wf-grid,.props-grid,.rent-summary,.acct-grid,.policy-grid{grid-template-columns:1fr 1fr;}
}
@media(max-width:640px){
